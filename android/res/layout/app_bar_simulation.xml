<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="android.SimulationActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/transparent"
        android:theme="@style/AppBarOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/background"
                app:navigationIcon="@drawable/exit"
                app:popupTheme="@style/PopupOverlay" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/menu_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/app_bar_shape"
                android:padding="5dp"
                android:scrollbarAlwaysDrawHorizontalTrack="true" />
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal">
                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/exit_minimized"
                        android:layout_marginEnd="5dp"
                        android:padding="5dp"
                        android:visibility="gone"
                        android:tint="@color/background"
                        android:background="@drawable/icon_ripple_oval_bg"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/exit"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/save_minimized"
                        android:layout_marginEnd="5dp"
                        android:layout_marginStart="50dp"
                        android:padding="5dp"
                        android:visibility="gone"
                        android:tint="@color/background"
                        android:background="@drawable/icon_ripple_oval_bg"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/save"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatToggleButton
                    android:id="@+id/simulation_toggle"
                    android:textOff=""
                    android:textOn=""
                    android:layout_centerHorizontal="true"
                    android:layout_centerVertical="true"
                    android:backgroundTint="@color/white"
                    android:background="@drawable/toggle_simulation_state"
                    android:checked="true"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/drawer_minimized"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="5dp"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:tint="@color/background"
                    android:background="@drawable/icon_ripple_oval_bg"
                    android:scaleType="fitCenter"
                    app:srcCompat="@drawable/menu"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
            </RelativeLayout>
        </LinearLayout>


    </com.google.android.material.appbar.AppBarLayout>

    <include layout="@layout/content_simulation" />
    </RelativeLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/component_bottom_sheet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/fab_margin"
        android:layout_marginBottom="16dp"
        android:src="@drawable/components"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
